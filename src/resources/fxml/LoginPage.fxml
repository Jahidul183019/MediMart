<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="ui.LoginPage"
            prefWidth="500" prefHeight="600"
            styleClass="root">

    <children>
        <VBox alignment="CENTER" spacing="20"
              AnchorPane.topAnchor="50" AnchorPane.bottomAnchor="50"
              AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50"
              styleClass="glass-pane">

            <!-- The background image for this Pane will be set in Java code -->
            <TextField fx:id="emailField" promptText="Email" styleClass="text-field"/>
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="password-field"/>

            <!-- Back Button (Newly added) -->
            <Button fx:id="backBtn" text="← Back" styleClass="btn-back" />

            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="loginBtn" text="Login" styleClass="btn-login"/>
                <Button fx:id="signupBtn" text="Sign Up" styleClass="btn-signup"/>
            </HBox>

            <Label fx:id="messageLabel" styleClass="message-label"/>
        </VBox>
    </children>
</AnchorPane>
